{
  "name": "veritas-fact-checking",
  "version": "1.0.0",
  "description": "Chrome extension for autonomous real-time fact checking",
  "author": "Veritas Team",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
